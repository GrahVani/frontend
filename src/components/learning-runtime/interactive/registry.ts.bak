/**
 * Interactive component registry.
 *
 * Maps a curriculum-side slug (declared in lesson front matter's
 * `interactive.component_type`) to the React component that renders it.
 *
 * All components use next/dynamic for on-demand loading — only the
 * component needed for the current lesson is compiled and shipped.
 */

import dynamic from "next/dynamic";
import type { ComponentType } from "react";

// eslint-disable-next-line @typescript-eslint/no-explicit-any
export type InteractiveComponentType = ComponentType<any>;

